{
  "name": "cohorte-multivault-prototype",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:lan": "vite --host 0.0.0.0",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "node --test src/*.test.js",
    "build:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "10.5.3",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "postcss": "8.5.19",
    "tailwindcss": "3.4.19",
    "vite": "^6.3.5"
  },
  "main": "./out/main/main.js",
  "build": {
    "appId": "com.cohorte.app",
    "productName": "Cohorte",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}